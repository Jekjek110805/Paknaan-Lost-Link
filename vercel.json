 {
   "version": 2,
   "builds": [
     {
       "src": "package.json",
       "use": "@vercel/static-build",
       "config": {
         "outputDirectory": "dist",
         "buildCommand": "npm run build"
       }
     },
     {
       "src": "server.ts",
       "use": "@vercel/node"
     }
   ],
   "routes": [
     { "src": "/api/(.*)", "dest": "server.ts" },
     { "src": "/uploads/(.*)", "dest": "server.ts" },
     { "src": "/(.*)", "dest": "dist/index.html" }
   ]
 }