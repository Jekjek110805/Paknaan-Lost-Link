{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "server.ts"
    }
  },
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
