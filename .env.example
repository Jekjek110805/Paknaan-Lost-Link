# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_VISION_MODEL="gemini-2.5-flash"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

# OpenAI image matching.
# Images are described by a vision model, then the description is embedded for vector search.
# If OPENAI_API_KEY is not configured, the app uses Gemini vision + Gemini embeddings
# when GEMINI_API_KEY exists, then local deterministic embeddings for demo matching.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_VISION_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Cloudinary storage for uploaded item/proof images.
CLOUDINARY_CLOUD_NAME="YOUR_CLOUDINARY_CLOUD_NAME"
CLOUDINARY_UPLOAD_PRESET="YOUR_UNSIGNED_UPLOAD_PRESET"
VITE_CLOUDINARY_CLOUD_NAME="YOUR_CLOUDINARY_CLOUD_NAME"
VITE_CLOUDINARY_UPLOAD_PRESET="YOUR_UNSIGNED_UPLOAD_PRESET"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# DATABASE_PATH: SQLite database file used by the Express backend.
DATABASE_PATH="./database.sqlite"

# JWT_SECRET: Change this before production.
JWT_SECRET="change-this-secret"

# Google OAuth / Gmail sign-in.
# Create an OAuth client in Google Cloud Console and add this redirect URI:
# http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
